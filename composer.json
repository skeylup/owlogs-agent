{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "skeylup/owlogs-agent",
    "description": "Owlogs agent — ship Laravel logs to an Owlogs server for aggregation and viewing.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Skeylup",
            "homepage": "https://www.owlogs.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/log": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/queue": "^11.0|^12.0|^13.0",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "monolog/monolog": "^3.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "orchestra/testbench": "^10.0.0||^9.0.0",
        "pestphp/pest": "^3.0||^4.0",
        "pestphp/pest-plugin-laravel": "^3.0||^4.0"
    },
    "autoload": {
        "psr-4": {
            "Skeylup\\OwlogsAgent\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Skeylup\\OwlogsAgent\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Skeylup\\OwlogsAgent\\OwlogsAgentServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
